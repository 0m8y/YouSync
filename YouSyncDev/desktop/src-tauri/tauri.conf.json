{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouSync",
  "version": "1.0.1",
  "identifier": "com.yousync.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost https: data:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    },
    "windows": [
      {
        "title": "YouSync",
        "width": 1100,
        "height": 650,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yousync-worker"
    ]
  }
}
